FROM debian:12-slim
RUN apt update && apt install -y git python3 python3-pip \
    python3-venv virtualenv && rm -rf /var/lib/apt/lists/*
RUN git clone https://github.com/sa7mon/miniprint
WORKDIR /miniprint
RUN virtualenv venv && ./venv/bin/pip3 install -r requirements.txt
EXPOSE 9100
CMD ["sh", "-c", "./venv/bin/python3 ./server.py -b 0.0.0.0"]
